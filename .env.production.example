# Copie para .env no servidor e preencha os valores.
#   cp .env.production.example .env && nano .env

# Banco de dados (senha forte — troque!)
POSTGRES_USER=gestrest
POSTGRES_PASSWORD=TROQUE_por_uma_senha_forte
POSTGRES_DB=gestrest

# Segredos JWT — gere com: openssl rand -hex 32
JWT_ACCESS_SECRET=TROQUE_gere_com_openssl_rand_hex_32
JWT_REFRESH_SECRET=TROQUE_outro_valor_openssl_rand_hex_32

# Porta pública no servidor. Deixe 80 para acesso direto (http://IP).
# Se este host já tem outro sistema na porta 80, use outra (ex.: 8081) e
# acesse por http://IP:8081.
HTTP_PORT=80

# URL pública do sistema. Sem barra no final. DEVE incluir a porta se não for 80.
# Ex. porta 80:    http://203.0.113.10
# Ex. porta 8081:  http://203.0.113.10:8081
PUBLIC_URL=http://SEU_IP_AQUI

# Nível de log do backend: fatal | error | warn | info | debug (padrão: info)
LOG_LEVEL=info
