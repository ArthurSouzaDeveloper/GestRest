// GestRest - Sistema de Gestão de Restaurante (multi-tenant)
// Modelo de dados normalizado (PostgreSQL + Prisma)
// Cada restaurante (tenant) tem seus próprios dados, isolados por restaurantId.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum Role {
  SUPERADMIN // Dono da plataforma — cria restaurantes (sem restaurantId)
  ADMIN
  MANAGER
  WAITER
  JUICER // Suqueiro
  COOK // Cozinheiro
  CASHIER // Caixa
}

// Estação de produção: para onde o item é roteado
enum Station {
  KITCHEN // Cozinha (comidas)
  JUICE_BAR // Suqueiros (bebidas)
  NONE // Itens que não passam por produção
}

enum TableStatus {
  FREE
  OCCUPIED
  IN_PRODUCTION
  READY_FOR_PAYMENT
  CLOSED
}

enum OrderStatus {
  OPEN
  IN_PRODUCTION
  READY_FOR_PAYMENT
  PAID
  CANCELLED
}

enum ProductionStatus {
  WAITING
  PREPARING
  DONE
  CANCELLED
}

enum PaymentMethod {
  PIX
  CASH
  CREDIT
  DEBIT
  MEAL_VOUCHER
}

enum AuditAction {
  ORDER_CREATED
  ORDER_UPDATED
  ORDER_CANCELLED
  ITEM_ADDED
  ITEM_UPDATED
  ITEM_REMOVED
  STATUS_CHANGED
  PAYMENT_RECEIVED
  TABLE_OPENED
  TABLE_CLOSED
  LOGIN
  USER_CREATED
  RESTAURANT_CREATED
}

// ─────────────────────────────────────────────────────────────
// TENANT: RESTAURANTE
// ─────────────────────────────────────────────────────────────

model Restaurant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique // identificador do "link próprio" (ex.: pizzaria-do-ze)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  categories  Category[]
  products    Product[]
  additionals Additional[]
  tables      RestaurantTable[]
  customers   Customer[]
  orders      Order[]
  payments    Payment[]
  auditLogs   AuditLog[]
  settings    Setting[]

  @@map("restaurants")
}

// ─────────────────────────────────────────────────────────────
// USUÁRIOS & PERMISSÕES
// ─────────────────────────────────────────────────────────────

model User {
  id           String      @id @default(uuid())
  name         String
  email        String      @unique
  passwordHash String
  role         Role        @default(WAITER)
  active       Boolean     @default(true)
  restaurantId String? // null apenas para SUPERADMIN
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  refreshTokens  RefreshToken[]
  ordersAsWaiter Order[]        @relation("WaiterOrders")
  auditLogs      AuditLog[]
  payments       Payment[]

  @@index([role])
  @@index([restaurantId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────
// CLIENTES & MESAS
// ─────────────────────────────────────────────────────────────

model Customer {
  id           String     @id @default(uuid())
  name         String
  phone        String?
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  orders Order[]

  @@index([restaurantId])
  @@map("customers")
}

model RestaurantTable {
  id           String      @id @default(uuid())
  number       Int
  status       TableStatus @default(FREE)
  seats        Int         @default(4)
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  orders Order[]

  @@unique([restaurantId, number])
  @@index([restaurantId, status])
  @@map("tables")
}

// ─────────────────────────────────────────────────────────────
// CATÁLOGO: CATEGORIAS, PRODUTOS, ADICIONAIS
// ─────────────────────────────────────────────────────────────

model Category {
  id           String     @id @default(uuid())
  name         String
  station      Station    @default(KITCHEN)
  sortOrder    Int        @default(0)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  products    Product[]
  additionals Additional[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@map("categories")
}

model Product {
  id           String     @id @default(uuid())
  name         String
  description  String?
  price        Decimal    @db.Decimal(10, 2)
  imageUrl     String?
  avgPrepMin   Int        @default(10)
  available    Boolean    @default(true)
  categoryId   String
  category     Category   @relation(fields: [categoryId], references: [id])
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  orderItems OrderItem[]

  @@index([restaurantId, available])
  @@index([categoryId])
  @@map("products")
}

model Additional {
  id           String     @id @default(uuid())
  name         String
  price        Decimal    @db.Decimal(10, 2) @default(0)
  active       Boolean    @default(true)
  categoryId   String?
  category     Category?  @relation(fields: [categoryId], references: [id])
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  orderItemAdditionals OrderItemAdditional[]

  @@index([restaurantId])
  @@map("additionals")
}

// ─────────────────────────────────────────────────────────────
// PEDIDOS (COMANDAS)
// ─────────────────────────────────────────────────────────────

model Order {
  id           String          @id @default(uuid())
  number       Int             @default(autoincrement())
  tableId      String
  table        RestaurantTable @relation(fields: [tableId], references: [id])
  customerId   String?
  customer     Customer?       @relation(fields: [customerId], references: [id])
  waiterId     String
  waiter       User            @relation("WaiterOrders", fields: [waiterId], references: [id])
  restaurantId String
  restaurant   Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  status       OrderStatus     @default(OPEN)
  peopleCount  Int             @default(1)
  notes        String?
  serviceRate  Decimal         @db.Decimal(5, 2) @default(10)
  discount     Decimal         @db.Decimal(10, 2) @default(0)
  version      Int             @default(0)
  openedAt     DateTime        @default(now())
  closedAt     DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  items    OrderItem[]
  payments Payment[]

  @@index([restaurantId, status])
  @@index([tableId])
  @@index([waiterId])
  @@map("orders")
}

model OrderItem {
  id         String           @id @default(uuid())
  orderId    String
  order      Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    Product          @relation(fields: [productId], references: [id])
  quantity   Int              @default(1)
  unitPrice  Decimal          @db.Decimal(10, 2)
  notes      String?
  station    Station          @default(KITCHEN)
  status     ProductionStatus @default(WAITING)
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  additionals OrderItemAdditional[]

  @@index([orderId])
  @@index([station, status])
  @@map("order_items")
}

model OrderItemAdditional {
  id           String     @id @default(uuid())
  orderItemId  String
  orderItem    OrderItem  @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  additionalId String
  additional   Additional @relation(fields: [additionalId], references: [id])
  name         String
  price        Decimal    @db.Decimal(10, 2)

  @@map("order_item_additionals")
}

// ─────────────────────────────────────────────────────────────
// PAGAMENTOS
// ─────────────────────────────────────────────────────────────

model Payment {
  id           String        @id @default(uuid())
  orderId      String
  order        Order         @relation(fields: [orderId], references: [id])
  method       PaymentMethod
  amount       Decimal       @db.Decimal(10, 2)
  change       Decimal       @db.Decimal(10, 2) @default(0)
  cashierId    String
  cashier      User          @relation(fields: [cashierId], references: [id])
  restaurantId String
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())

  @@index([orderId])
  @@index([restaurantId, createdAt])
  @@map("payments")
}

// ─────────────────────────────────────────────────────────────
// AUDITORIA / LOGS
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id           String      @id @default(uuid())
  action       AuditAction
  userId       String?
  user         User?       @relation(fields: [userId], references: [id])
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  entity       String?
  entityId     String?
  ip           String?
  metadata     Json?
  createdAt    DateTime    @default(now())

  @@index([restaurantId, createdAt])
  @@index([action])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────
// CONFIGURAÇÕES
// ─────────────────────────────────────────────────────────────

model Setting {
  id           String     @id @default(uuid())
  key          String
  value        String
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  updatedAt    DateTime   @updatedAt

  @@unique([restaurantId, key])
  @@map("settings")
}
